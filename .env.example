# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
SECRET_KEY=change-me-to-a-long-random-string

# Database
DATABASE_PATH=data/tracker.db

# Scheduler (cron-like, default: every hour on the 7th minute)
CHECK_INTERVAL_MINUTES=60

# Discord bot
DISCORD_BOT_TOKEN=
DISCORD_NOTIFY_CHANNEL_ID=
# Only users listed here (Discord user IDs, comma-separated) can use bot commands
DISCORD_ADMIN_IDS=

# Notifications
# Minimum price drop (percent) required to send a notification
MIN_DROP_PERCENT=1.0
# Also notify when the product goes back in stock
NOTIFY_ON_STOCK_CHANGE=true

# Scraper
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36
REQUEST_TIMEOUT=20
